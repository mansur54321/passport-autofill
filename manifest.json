{
  "manifest_version": 3,
  "name": "Passport AutoFill (Multi-Operator)",
  "version": "6.0.0",
  "description": "Auto-fill passport data for travel B2B sites (PDF Drag&Drop, OCR, Templates)",
  "permissions": ["activeTab", "storage", "scripting", "alarms", "notifications", "tabs"],
  "host_permissions": [
    "*://*.fstravel.asia/*",
    "*://*.fstravel.com/*",
    "*://*.kompastour.kz/*",
    "*://*.kompastour.com/*",
    "*://*.kazunion.com/*",
    "file://*/*",
    "https://api.github.com/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "passport-autofill@fstravel.asia",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.fstravel.asia/*",
        "*://*.fstravel.com/*",
        "*://*.kompastour.kz/*",
        "*://*.kompastour.com/*",
        "*://*.kazunion.com/*",
        "file://*/*"
      ],
      "js": ["pdf.min.js", "utils.js", "passport-parser.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.min.js", "icon.png", "tesseract.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "open-file-dialog": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open passport file dialog"
    }
  }
}
